# 阿里云百炼 API Key (在阿里云控制台获取)
DASHSCOPE_API_KEY=
OPENAI_API_KEY=
# 阿里云百炼 OpenAI 兼容接口地址
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 模型名称 (阿里云百炼支持通义千问系列，如 qwen-max, qwen-plus)
# 推荐 qwen-max 用于复杂分析，qwen-plus 用于性价比
MODEL_NAME=
# 其他配置
LOG_LEVEL=INFO
# 服务端口
PORT=8000
# 新增：Embedding 模型配置
EMBEDDING_MODEL=
